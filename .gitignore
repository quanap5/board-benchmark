# Ignore everything
*

# Allow benchmarkCLI folder
!benchmarkCLI/
!benchmarkCLI/**

# Ignore artifacts inside benchmarkCLI
benchmarkCLI/.venv/
benchmarkCLI/.venv-pc/
benchmarkCLI/models/*.pt
benchmarkCLI/models/*.engine
benchmarkCLI/models/*-convert.log
benchmarkCLI/models-pc/*.pt
benchmarkCLI/models-pc/*.engine
__pycache__/
*.pyc

# Allow root files
!.gitignore
!README.md
!LICENSE

# Allow docs folder
!docs/
!docs/**
